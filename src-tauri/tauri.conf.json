{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mnemo",
  "version": "0.1.0",
  "identifier": "com.mnemo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Mnemo",
        "width": 1000,
        "height": 700,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true
      },
      {
        "label": "popup",
        "title": "Mnemo Quick Search",
        "width": 600,
        "height": 400,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset: http://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Your clipboard, with memory."
  }
}
